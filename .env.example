# Backend
# URL de conexión SQLAlchemy (sin credenciales reales)
DATABASE_URL=postgresql+psycopg://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:<DB_PORT>/<DB_NAME>

# Orígenes permitidos para CORS separados por coma
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# URL pública/base del backend para construir URLs de archivos subidos
APP_BASE_URL=http://127.0.0.1:8000

# Directorio donde se guardan los uploads
UPLOAD_DIR=uploads
