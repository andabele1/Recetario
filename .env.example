# Backend
# URL de conexión SQLAlchemy (sin credenciales reales)
DATABASE_URL=postgresql+psycopg://<postgres>:<aNDABELE*1>@<ocalhost>:<5432>/<postgres>

# Orígenes permitidos para CORS separados por coma
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://recetario-peach.vercel.app

# URL pública/base del backend para construir URLs de archivos subidos
APP_BASE_URL=http://127.0.0.1:8000,https://recetario-wa6k.vercel.app

# Directorio donde se guardan los uploads
UPLOAD_DIR=uploads
